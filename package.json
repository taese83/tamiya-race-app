{
  "name": "tamiya-race-app",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.14.0",
  "engines": {"node": ">=22.11.0"},
  "scripts": {
    "dev": "concurrently \"pnpm --filter server dev\" \"pnpm --filter client dev\"",
    "build": "node scripts/prepare-build.cjs && pnpm --filter client build",
    "server": "pnpm --filter server dev",
    "client": "pnpm --filter client dev",
    "crawl": "tsx scripts/crawl.ts"
  },
  "dependencies": {
    "axios": "^1.7.0",
    "cheerio": "^1.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "concurrently": "^9.0.0",
    "tsx": "^4.19.0",
    "typescript": "^6.0.0"
  }
}
