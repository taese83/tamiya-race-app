{
  "compilerOptions": {
    "composite": true, "target": "ES2022", "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "module": "ESNext", "moduleResolution": "Bundler", "skipLibCheck": true,
    "allowImportingTsExtensions": true, "isolatedModules": true, "noEmit": true,
    "jsx": "react-jsx", "strict": true, "noUnusedParameters": true,
    "ignoreDeprecations": "6.0",
    "baseUrl": ".", "paths": {"@/*": ["src/*"]}
  },
  "include": ["src"]
}
