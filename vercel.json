{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "buildCommand": "pnpm --filter client build",
  "outputDirectory": "client/dist",
  "installCommand": "pnpm install",
  "framework": null,
  "crons": [
    {
      "path": "/api/cron/crawl",
      "schedule": "0 15 * * *"
    }
  ],
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/api/$1"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
